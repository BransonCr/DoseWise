<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- TASK 2: DOSE LOGGING (Aaron) -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.myapplication.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_dose_confirmation"
            app:destination="@id/doseConfirmationFragment">
            <argument
                android:name="medicationName"
                app:argType="string"
                app:nullable="true" />
        </action>

        <action
            android:id="@+id/action_home_to_missedDose"
            app:destination="@id/missedDoseFragment" />

        <action
            android:id="@+id/action_home_to_reminderTiming"
            app:destination="@id/reminderTimingFragment" />

        <action
            android:id="@+id/action_home_to_addMedication"
            app:destination="@id/addMedicationFragment" />

        <action
            android:id="@+id/action_home_to_refill"
            app:destination="@id/refillFragment" />

        <action
            android:id="@+id/action_home_to_caregiverDashboard"
            app:destination="@id/caregiverDashboardFragment" />

        <action
            android:id="@+id/action_home_to_pharmacyLocator"
            app:destination="@id/pharmacyLocatorActivity" />
    </fragment>

    <fragment
        android:id="@+id/doseConfirmationFragment"
        android:name="com.example.myapplication.DoseConfirmationFragment"
        android:label="Dose Confirmation"
        tools:layout="@layout/fragment_dose_confirmation" />

    <fragment
        android:id="@+id/missedDoseFragment"
        android:name="com.example.myapplication.MissedDoseFragment"
        android:label="Missed Doses"
        tools:layout="@layout/fragment_missed_dose" />

    <!-- TASK 1: MEDICATION SETUP (Branson) -->

    <fragment
        android:id="@+id/addMedicationFragment"
        android:name="com.example.myapplication.AddMedicationFragment"
        android:label="Add Medication"
        tools:layout="@layout/fragment_add_medication">
        <action
            android:id="@+id/action_addMedication_to_reviewMedication"
            app:destination="@id/reviewMedicationFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewMedicationFragment"
        android:name="com.example.myapplication.ReviewMedicationFragment"
        android:label="Review Medication"
        tools:layout="@layout/fragment_review_medication">
        <action
            android:id="@+id/action_reviewMedication_to_medicationConfirmation"
            app:destination="@id/medicationConfirmationFragment" />
    </fragment>

    <fragment
        android:id="@+id/medicationConfirmationFragment"
        android:name="com.example.myapplication.MedicationConfirmationFragment"
        android:label="Medication Confirmation"
        tools:layout="@layout/fragment_medication_confirmation" />

    <!-- TASK 4: CAREGIVER MONITORING (Talon) -->

    <fragment
        android:id="@+id/caregiverDashboardFragment"
        android:name="com.example.myapplication.CaregiverDashboardFragment"
        android:label="Caregiver Dashboard"
        tools:layout="@layout/fragment_caregiver_dashboard">

        <action
            android:id="@+id/action_caregiverDashboard_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_caregiverDashboard_to_missedAlertList"
            app:destination="@id/missedAlertListFragment" />

        <action
            android:id="@+id/action_caregiverDashboard_to_weeklySummary"
            app:destination="@id/weeklySummaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/weeklySummaryFragment"
        android:name="com.example.myapplication.WeeklySummaryFragment"
        android:label="Weekly Summary"
        tools:layout="@layout/fragment_weekly_summary" />

    <fragment
        android:id="@+id/missedAlertListFragment"
        android:name="com.example.myapplication.MissedAlertListFragment"
        android:label="Missed Alerts"
        tools:layout="@layout/fragment_missed_alert_list" />

    <!-- TASK 3: REMINDER SETUP (Ben) -->

    <fragment
        android:id="@+id/reminderTimingFragment"
        android:name="com.example.myapplication.ReminderTimingFragment"
        android:label="Reminder Timing"
        tools:layout="@layout/fragment_reminder_timing">
        <action
            android:id="@+id/action_timing_to_tone"
            app:destination="@id/reminderToneFragment" />
    </fragment>

    <fragment
        android:id="@+id/reminderToneFragment"
        android:name="com.example.myapplication.ReminderToneFragment"
        android:label="Reminder Tone"
        tools:layout="@layout/fragment_reminder_tone">
        <action
            android:id="@+id/action_tone_to_confirmation"
            app:destination="@id/reminderConfirmationFragment" />
    </fragment>

    <fragment
        android:id="@+id/reminderConfirmationFragment"
        android:name="com.example.myapplication.ReminderConfirmationFragment"
        android:label="Reminder Confirmation"
        tools:layout="@layout/fragment_reminder_confirmation">

        <action
            android:id="@+id/action_confirmation_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/reminderTimingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/refillFragment"
        android:name="com.example.myapplication.RefillFragment"
        android:label="Refill Tracking"
        tools:layout="@layout/fragment_refill">
        <action
            android:id="@+id/action_refill_to_addMedication"
            app:destination="@id/addMedicationFragment" />
        <action
            android:id="@+id/action_refill_to_pharmacyLocator"
            app:destination="@id/pharmacyLocatorActivity" />
    </fragment>

    <activity
        android:id="@+id/pharmacyLocatorActivity"
        android:name="com.example.myapplication.PharmacyLocatorFragment"
        android:label="Pharmacy Locator" />

</navigation>
