<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".CaregiverDashboardFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- BLUE HEADER SECTION -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerSection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:padding="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/monitorTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/caregiver_monitor_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/initialsCircle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/primary_variant"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/monitorTitle"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/dependentInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="MT" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/dependentNameText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/dependentRoleText"
                    app:layout_constraintEnd_toStartOf="@id/chevronText"
                    app:layout_constraintStart_toEndOf="@id/initialsCircle"
                    app:layout_constraintTop_toTopOf="@id/initialsCircle"
                    app:layout_constraintVertical_chainStyle="packed"
                    tools:text="Margaret Thompson" />

                <TextView
                    android:id="@+id/dependentRoleText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:alpha="0.8"
                    android:text="@string/caregiver_dependent_role_label"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@id/initialsCircle"
                    app:layout_constraintEnd_toStartOf="@id/chevronText"
                    app:layout_constraintStart_toEndOf="@id/initialsCircle"
                    app:layout_constraintTop_toBottomOf="@id/dependentNameText" />

                <TextView
                    android:id="@+id/chevronText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="@string/caregiver_switch_dependent"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    app:layout_constraintBottom_toBottomOf="@id/initialsCircle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/initialsCircle" />

                <!-- Today's Adherence Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/adherenceCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/initialsCircle"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/adherenceLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/caregiver_adherence_title"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/adherencePercentageText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:paddingTop="4dp"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adherenceLabel" />

                        <TextView
                            android:id="@+id/takenCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adherencePercentageText" />

                        <TextView
                            android:id="@+id/missedCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/takenCountText" />

                        <TextView
                            android:id="@+id/upcomingCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/missedCountText" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- TAB TOGGLE -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tabToggle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:background="@color/screen_background"
                android:padding="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerSection">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/alertsTab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/caregiver_alerts_tab"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/weeklyTab"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/weeklyTab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/caregiver_weekly_tab"
                    android:textAllCaps="false"
                    android:textColor="@color/text_secondary"
                    app:backgroundTint="@color/screen_background"
                    app:cornerRadius="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/alertsTab"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ALERTS TAB CONTENT -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/alertsContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:visibility="visible"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tabToggle">

                <TextView
                    android:id="@+id/missedDosesHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/caregiver_missed_doses_header"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/missedListContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/missedDosesHeader" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- WEEKLY SUMMARY TAB CONTENT -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/weeklyContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tabToggle">

                <!-- Adherence Trend Card (Line Chart) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/adherenceTrendCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/adherenceTrendTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/weekly_adherence_trend_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/adherenceTrendSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/weekly_adherence_trend_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adherenceTrendTitle" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/adherenceTrendChart"
                            android:layout_width="0dp"
                            android:layout_height="220dp"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adherenceTrendSubtitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Daily Breakdown Card (Bar Chart) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dailyBreakdownCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/adherenceTrendCard"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/dailyBreakdownTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/weekly_daily_breakdown_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/dailyBreakdownSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/weekly_daily_breakdown_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/dailyBreakdownTitle" />

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/dailyBreakdownChart"
                            android:layout_width="0dp"
                            android:layout_height="220dp"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/dailyBreakdownSubtitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats Row Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/weeklySummaryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dailyBreakdownCard"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/weeklyTakenCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/weeklyMissedCount"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="23" />

                        <TextView
                            android:id="@+id/weeklyTakenLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/caregiver_doses_taken_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toStartOf="@id/weeklyMissedLabel"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/weeklyTakenCount" />

                        <TextView
                            android:id="@+id/weeklyMissedCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/accent"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/weeklyAdherenceRate"
                            app:layout_constraintStart_toEndOf="@id/weeklyTakenCount"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="5" />

                        <TextView
                            android:id="@+id/weeklyMissedLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/caregiver_doses_missed_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toStartOf="@id/weeklyRateLabel"
                            app:layout_constraintStart_toEndOf="@id/weeklyTakenLabel"
                            app:layout_constraintTop_toBottomOf="@id/weeklyMissedCount" />

                        <TextView
                            android:id="@+id/weeklyAdherenceRate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/primary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/weeklyMissedCount"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="82%" />

                        <TextView
                            android:id="@+id/weeklyRateLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/caregiver_adherence_rate_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/weeklyMissedLabel"
                            app:layout_constraintTop_toBottomOf="@id/weeklyAdherenceRate" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
